{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "v2/components/Alert/**",
              "v2/components/AppLayout/**",
              "v2/components/AreaChart/**",
              "v2/components/AttributeEditor/**",
              "v2/components/Autosuggest/**",
              "v2/components/Badge/**",
              "v2/components/BarChart/**",
              "v2/components/Box/**",
              "v2/components/BreadcrumbGroup/**",
              "v2/components/Button/**",
              "v2/components/ButtonDropdown/**",
              "v2/components/ButtonGroup/**",
              "v2/components/Cards/**",
              "v2/components/Checkbox/**",
              "v2/components/CollectionPreferences/**",
              "v2/components/ColumnLayout/**",
              "v2/components/Container/**",
              "v2/components/ContentLayout/**",
              "v2/components/CopyToClipboard/**",
              "v2/components/DatePicker/**",
              "v2/components/Drawer/**",
              "v2/components/ExpandableSection/**",
              "v2/components/FileUpload/**",
              "v2/components/Flashbar/**",
              "v2/components/Form/**",
              "v2/components/FormField/**",
              "v2/components/Grid/**",
              "v2/components/Header/**",
              "v2/components/HelpPanel/**",
              "v2/components/Hotspot/**",
              "v2/components/Input/**",
              "v2/components/KeyValuePairs/**",
              "v2/components/LineChart/**",
              "v2/components/Link/**",
              "v2/components/LiveRegion/**",
              "v2/components/MixedChart/**",
              "v2/components/Modal/**",
              "v2/components/Multiselect/**",
              "v2/components/Pagination/**",
              "v2/components/PieChart/**",
              "v2/components/Popover/**",
              "v2/components/ProgressBar/**",
              "v2/components/PromptInput/**",
              "v2/components/PropertyFilter/**",
              "v2/components/RadioGroup/**",
              "v2/components/SegmentedControl/**",
              "v2/components/Select/**",
              "v2/components/SideNavigation/**",
              "v2/components/Slider/**",
              "v2/components/SpaceBetween/**",
              "v2/components/Spinner/**",
              "v2/components/SplitPanel/**",
              "v2/components/StatusIndicator/**",
              "v2/components/Steps/**",
              "v2/components/Table/**",
              "v2/components/Tabs/**",
              "v2/components/TextFilter/**",
              "v2/components/Textarea/**",
              "v2/components/Tiles/**",
              "v2/components/Toggle/**",
              "v2/components/ToggleButton/**",
              "v2/components/TokenGroup/**",
              "v2/components/TopNavigation/**",
              "v2/components/TutorialPanel/**",
              "v2/components/Wizard/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Syne|Space Grotesk|Inter|JetBrains Mono))/i]",
        "message": "Font not provided by the design system. Available: Syne, Space Grotesk, Inter, JetBrains Mono."
      },
      {
        "selector": "JSXOpeningElement[name.name='Alert'] > JSXAttribute > JSXIdentifier[name!=/^(?:type|header|dismissible|onDismiss|action|children|key|ref|className|style|children)$/]",
        "message": "<Alert> doesn't accept that prop. Declared props: type, header, dismissible, onDismiss, action, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Alert'] > JSXAttribute[name.name='type'] > Literal[value!=/^(?:info|success|warning|error)$/]",
        "message": "<Alert> type must be one of 'info' | 'success' | 'warning' | 'error'."
      },
