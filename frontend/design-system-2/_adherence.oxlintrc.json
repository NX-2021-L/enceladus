        "selector": "JSXOpeningElement[name.name='AppLayout'] > JSXAttribute > JSXIdentifier[name!=/^(?:topNavigation|navigation|navigationOpen|breadcrumbs|content|tools|toolsOpen|splitPanel|key|ref|className|style|children)$/]",
        "message": "<AppLayout> doesn't accept that prop. Declared props: topNavigation, navigation, navigationOpen, breadcrumbs, content, tools, toolsOpen, splitPanel."
