# Base URL for the Enceladus read API.
# Default (when unset) is /api/v1 — mirrors the existing app's
# normalizeApiBaseUrl(import.meta.env.VITE_API_BASE_URL) default in
# frontend/ui/src/api/projects.ts. Tracker records are read from
# ${VITE_API_BASE}/tracker/{project}/{type}/{id}; documents from
# ${VITE_API_BASE}/documents/{id}.
VITE_API_BASE=/api/v1
